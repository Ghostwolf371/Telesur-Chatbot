# Django
DEBUG=1
SECRET_KEY=replace-me-in-production
ALLOWED_HOSTS=*
DJANGO_DB_ENGINE=sqlite3

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=telesur_chatbot

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000
CHROMA_COLLECTION=telesur_docs
RAG_TOP_K=3

# Ollama
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TIMEOUT_SECONDS=180
# Use Ollama neural embeddings for RAG (1=on, 0=fallback to hash-based)
USE_OLLAMA_EMBEDDINGS=1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# User testing mode (enables feedback panel in chat UI)
NEXT_PUBLIC_SHOW_TEST_FEEDBACK_PANEL=1

# Chat behavior
SUMMARY_TRIGGER_EVERY=10
SAFETY_REFUSAL_MESSAGE=I cannot help with requests for secrets, credentials, or instruction bypass attempts.
ANON_RATE_LIMIT=120/min
CHAT_RATE_LIMIT=30/min
SUMMARIZE_RATE_LIMIT=20/min
FEEDBACK_RATE_LIMIT=30/min
# Long-context memory controls
TELEBOT_MEMORY_FETCH_LIMIT=40
TELEBOT_PROMPT_RECENT_MESSAGES=10
TELEBOT_PROMPT_RECENT_TOKENS=1200
TELEBOT_RETRIEVAL_RECENT_USER_TURNS=6
TELEBOT_RETRIEVAL_RECENT_TOKENS=400
TELEBOT_SUMMARY_RECENT_MESSAGES=24
TELEBOT_SUMMARY_RECENT_TOKENS=1400
GUNICORN_WORKERS=2
GUNICORN_TIMEOUT=180

# CORS (browser frontend on localhost:3000)
CORS_ALLOW_ALL_ORIGINS=1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Validation thresholds (teacher rubric helpers)
VALIDATION_MIN_TESTERS=3
VALIDATION_MIN_CONVERSATIONS=20
VALIDATION_MIN_FEEDBACK=3

# Automatic RAG refresh scheduler
RAG_AUTO_REFRESH_ENABLED=1
RAG_REFRESH_INTERVAL_MINUTES=360
RAG_SCRAPE_BASE_URL=https://www.telesur.sr
RAG_SCRAPE_MAX_PAGES=50
RAG_REFRESH_RESET=0
RAG_ALLOW_SCRAPE_FAILURE=1
